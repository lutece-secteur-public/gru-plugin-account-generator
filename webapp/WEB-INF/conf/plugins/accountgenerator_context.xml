<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd" >

    <!-- Cache -->
    <bean id="accountgenerator.geocodesCache"  class="fr.paris.lutece.plugins.accountgenerator.service.GeocodesCache" />

    <!-- DAO -->
    <bean id="accountgenerator.accountDao" class="fr.paris.lutece.plugins.accountgenerator.business.IdentityAccountDao" />
    <bean id="accountgenerator.jobDao" class="fr.paris.lutece.plugins.accountgenerator.business.AccountGenerationJobDao" />

    <!-- File storage for generated CSV files -->
    <bean id="accountgenerator.defaultFileDownloadUrlService" class="fr.paris.lutece.portal.service.file.implementation.DefaultFileDownloadService" />
    <bean id="accountgenerator.defaultFileNoRBACService" class="fr.paris.lutece.portal.service.file.implementation.DefaultFileNoRBACService" />

    <bean id="accountgenerator.localFileSystemDirectoryFileService" class="fr.paris.lutece.plugins.accountgenerator.service.file.implementation.LocalFileSystemDirectoryFileService">
        <constructor-arg value="${accountgenerator.filesystem.path}" />
        <constructor-arg ref="accountgenerator.defaultFileDownloadUrlService" />
        <constructor-arg ref="accountgenerator.defaultFileNoRBACService" />
        <property name="name" value="accountgenerator.localFileSystemDirectoryFileService" />
    </bean>

    <!-- Async executor for account generation jobs -->
    <bean id="accountgenerator.jobExecutor" class="java.util.concurrent.Executors" factory-method="newFixedThreadPool" destroy-method="shutdown">
        <constructor-arg type="int" value="${accountgenerator.executor.threads}" />
    </bean>

    <!-- Job service -->
    <bean id="accountgenerator.jobService" class="fr.paris.lutece.plugins.accountgenerator.service.AccountGenerationJobService">
        <constructor-arg ref="accountgenerator.jobExecutor" />
    </bean>

    <!-- IHttpTransportProvider declarations -->
    <bean id="accountgenerator.identitystore.httpAccessTransport" class="fr.paris.lutece.plugins.identitystore.v3.web.rs.service.HttpApiManagerAccessTransport" >
        <property name="ApiEndPointUrl">
            <value>${accountgenerator.identitystore.ApiEndPointUrl}</value>
        </property>
        <property name="AccessManagerEndPointUrl">
            <value>${accountgenerator.identitystore.accessManagerEndPointUrl}</value>
        </property>
        <property name="AccessManagerCredentials">
            <value>${accountgenerator.identitystore.accessManagerCredentials}</value>
        </property>
    </bean>

    <bean id="accountgenerator.accountManagement.httpAccessTransport" class="fr.paris.lutece.plugins.accountmanagement.web.rs.service.HttpAccessTransport" >
        <property name="ApiEndPointUrl">
            <value>${accountgenerator.accountManagement.ApiEndPointUrl}</value>
        </property>
    </bean>

    <bean id="accountgenerator.restTransport.httpAccess" class="fr.paris.lutece.plugins.identitystore.v3.web.rs.service.IdentityTransportRest">
        <constructor-arg ref="accountgenerator.identitystore.httpAccessTransport"/>
    </bean>

    <bean id="accountgenerator.restAccountManagementTransport.httpAccess" class="fr.paris.lutece.plugins.accountmanagement.web.rs.service.transportrest.AccountManagementTransportRest">
        <constructor-arg ref="accountgenerator.accountManagement.httpAccessTransport"/>
        <constructor-arg type="java.lang.String" value="${accountgenerator.accountManagement.path}" />
    </bean>

    <!-- Service impl -->
    <bean id="accountgenerator.identityService" class="fr.paris.lutece.plugins.identitystore.v3.web.service.IdentityService">
        <constructor-arg ref="accountgenerator.restTransport.httpAccess"/>
    </bean>
    <bean id="accountgenerator.accountManagementService" class="fr.paris.lutece.plugins.accountmanagement.web.service.AccountManagementService">
        <constructor-arg ref="accountgenerator.restAccountManagementTransport.httpAccess"/>
    </bean>

    <!-- REST -->
    <bean id="accountgenerator.accountGeneratorRestService"  class="fr.paris.lutece.plugins.accountgenerator.web.rs.AccountGeneratorRestService" />
</beans>
